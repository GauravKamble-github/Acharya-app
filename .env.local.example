# ============================================================================
# Unified Acharya app - environment variables
# ============================================================================

# Supabase project containing:
# - gunakul schema for mst_acharyas, mst_users, map_category_acharya, logs
# - acharya_arjun, acharya_farmer, acharya_vajra, acharya_taksha schemas
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Root / redirects here. Valid values: arjun, farmer, vajra, taksha.
NEXT_PUBLIC_DEFAULT_ACHARYA=farmer

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Google TTS
GOOGLE_TTS_KEY=your-google-tts-key-here

# Optional Gemini Live voice mode.
GEMINI_API_KEY=your-gemini-key-here
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Optional live mandi prices for Farmer tools.
DATA_GOV_API_KEY=your-data-gov-key-here

# Admin login credentials for /{acharya}/admin.
NEXT_PUBLIC_ADMIN_EMAIL=admin@acharya.app
ADMIN_PASSWORD=change-this-admin-password

# HMAC key for learner/admin session cookies.
SESSION_SECRET=change-me-to-a-long-random-string
